# Copy to `.env.local` (gitignored) and restart `npm run dev` so Vite picks up `VITE_*` vars.
#
# Relay runs every AI feature through your local Ollama server — there are no
# hosted-LLM API keys to set. Configure the Ollama base URL and per-tier model
# tags from inside the app under Settings → Models & connectivity.

# --- Optional local speech-to-text sidecar ------------------------------------
# Run in a separate terminal: `npm run local-stt` (then `npm run dev` in another).
# Reference server: `scripts/local-stt-server.mjs` (listens on 127.0.0.1, default 9000).
# When this is unset, tap-to-speak relies entirely on the browser Web Speech API.
VITE_RELAY_LOCAL_STT_URL=http://127.0.0.1:9000

# On the sidecar process only (not a Vite var): shell command template that prints
# the transcript to stdout. Placeholders: {input} path to audio file, {language} BCP-47.
# Example: RELAY_STT_CMD='./scripts/my-local-transcribe.sh {input} {language}'
